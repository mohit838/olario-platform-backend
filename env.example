# Olario Platform Environment Template
# Copy to .env and replace placeholder values for your environment.
# Do not commit real secrets.

# ==============================================================================
# GENERAL
# ==============================================================================
NODE_ENV=local
ENVIRONMENT=local
APP_NAME=olario-platform
APP_VERSION=0.1.0-m1
TZ=UTC

# ==============================================================================
# VERSION TARGETS
# ==============================================================================
POSTGRES_VERSION=17
KONG_VERSION=latest
JAVA_VERSION=21
GO_VERSION=1.26
DROGON_VERSION=latest
ANGULAR_VERSION=lts
NODE_VERSION=24.15.0

# ==============================================================================
# POSTGRESQL (17) - PROVIDED BY LOCAL MACHINE
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=CHANGE_ME_POSTGRES_ROOT_PASSWORD

CMS_DB_NAME=olario_cms_db
CMS_DB_USER=CHANGE_ME_CMS_DB_USER
CMS_DB_PASSWORD=CHANGE_ME_CMS_DB_PASSWORD
CMS_DATABASE_URL=postgresql://CHANGE_ME_CMS_DB_USER:CHANGE_ME_CMS_DB_PASSWORD@localhost:5432/olario_cms_db

CATALOG_DB_NAME=olario_catalog_db
CATALOG_DB_USER=CHANGE_ME_CATALOG_DB_USER
CATALOG_DB_PASSWORD=CHANGE_ME_CATALOG_DB_PASSWORD
CATALOG_DATABASE_URL=postgresql://CHANGE_ME_CATALOG_DB_USER:CHANGE_ME_CATALOG_DB_PASSWORD@localhost:5432/olario_catalog_db

HEAVY_DB_NAME=olario_heavy_db
HEAVY_DB_USER=CHANGE_ME_HEAVY_DB_USER
HEAVY_DB_PASSWORD=CHANGE_ME_HEAVY_DB_PASSWORD
HEAVY_DATABASE_URL=postgresql://CHANGE_ME_HEAVY_DB_USER:CHANGE_ME_HEAVY_DB_PASSWORD@localhost:5432/olario_heavy_db

# ==============================================================================
# KONG (LATEST STABLE)
# ==============================================================================
KONG_DATABASE=postgres
KONG_PG_HOST=localhost
KONG_PG_PORT=5432
KONG_PG_USER=CHANGE_ME_KONG_DB_USER
KONG_PG_PASSWORD=CHANGE_ME_KONG_DB_PASSWORD
KONG_PG_DATABASE=kong_db
KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

# ==============================================================================
# SERVICES
# ==============================================================================
CMS_SERVICE_HOST=cms-service
CMS_SERVICE_PORT=8081
CATALOG_SERVICE_HOST=catalog-service
CATALOG_SERVICE_PORT=8082
HEAVY_SERVICE_HOST=heavy-service
HEAVY_SERVICE_PORT=8083

GRPC_ENABLED=true
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ==============================================================================
# FRONTEND (ANGULAR LTS, NODE 24.15.0)
# ==============================================================================
FRONTEND_HOST=frontend
FRONTEND_PORT=4200
API_URL=http://localhost:8000/api
GATEWAY_URL=http://localhost:8000

# ==============================================================================
# MINIO - PROVIDED BY LOCAL MACHINE
# ==============================================================================
MINIO_HOST=localhost
MINIO_API_PORT=1239
MINIO_CONSOLE_PORT=1240
MINIO_ROOT_USER=CHANGE_ME_MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_ROOT_PASSWORD
S3_ENDPOINT=http://localhost:1239
S3_ACCESS_KEY=CHANGE_ME_S3_ACCESS_KEY
S3_SECRET_KEY=CHANGE_ME_S3_SECRET_KEY
S3_REGION=us-east-1

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=1236
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# ==============================================================================
# KAFKA - PROVIDED BY LOCAL MACHINE
# ==============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_ORDERS=olario.orders
KAFKA_TOPIC_EVENTS=olario.events
KAFKA_TOPIC_PAYMENTS=olario.payments
KAFKA_TOPIC_INVENTORY=olario.inventory

# ==============================================================================
# SECURITY PLACEHOLDERS
# ==============================================================================
JWT_SECRET=CHANGE_ME_JWT_SECRET
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=CHANGE_ME_OPENBAO_TOKEN

# ==============================================================================
# OBSERVABILITY (ADD LATER)
# ==============================================================================
ENABLE_OBSERVABILITY=false
LOKI_ENABLED=false
PROMETHEUS_ENABLED=false
CADVISOR_ENABLED=false
GRAFANA_ENABLED=false

# ==============================================================================
# NOTES
# ==============================================================================
# 1) Replace all CHANGE_ME_* values before non-local use.
# 2) Keep .env files out of git.
# 3) Prefer secret manager integration for shared/staging/production environments.
# 4) PostgreSQL/Kafka/MinIO/Redis are expected from local machine services.
